# The Wire — Environment Variables
# Copy this to .env and fill in your keys

# Required: Anthropic API key for article generation
ANTHROPIC_API_KEY=sk-ant-...

# Required: Virlo API key for trend intelligence
# Get 500 free credits at: https://dev.virlo.ai
VIRLO_API_KEY=virlo_tkn_...

# Optional: Port (default 3000)
PORT=3000

# Optional: Cache TTL in seconds (default 3600 = 1hr)
# Articles are expensive to generate - cache aggressively
CACHE_TTL=3600

# Optional: Refresh the front page story list every N seconds (default 21600 = 6hrs)
STORY_REFRESH_INTERVAL=21600

# Optional: Node environment
NODE_ENV=production
